{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Winds Restore",
  "version": "0.1.0",
  "identifier": "io.github.widue.winds-restore",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Winds Restore",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
